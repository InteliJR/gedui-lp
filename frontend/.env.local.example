# =====================================================
# CONFIGURAÇÃO DO CALENDLY - API DE AGENDAMENTO
# =====================================================
# Este arquivo serve como template. Copie para .env.local
# Na Vercel, adicione estas variáveis em Settings > Environment Variables
#
# IMPORTANTE: Requer plano Calendly Professional ou superior
# para usar a API de agendamento programático (POST /invitees)
#
# Obtenha seu token em: https://calendly.com/integrations/api_webhooks
# =====================================================

CALENDLY_API_KEY=

# =====================================================
# VARIÁVEIS OPCIONAIS (preenchidas automaticamente)
# =====================================================
# URI do usuário Calendly - detectada automaticamente pela API
# Formato: https://api.calendly.com/users/XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
# CALENDLY_USER_URI=

# Nome do tipo de evento para agendamento (opcional)
# Se não definido, usa o primeiro evento ativo da conta
# Ex: "Demonstração GEDUI", "Reunião 30 min"
# CALENDLY_EVENT_TYPE_NAME=
